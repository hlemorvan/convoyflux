    "maplibre-gl":      "^5.0.0"
  },
  "devDependencies": {
    "@types/react":             "^19.0.0",
    "@types/react-dom":         "^19.0.0",
    "@vitejs/plugin-react":     "^4.3.0",
    "vite":                     "^6.0.0",
    "typescript":               "~5.7.0",
    "tailwindcss":              "^4.0.0",
    "@tailwindcss/vite":        "^4.0.0",
    "vitest":                   "^2.1.0",
    "@vitest/coverage-v8":      "^2.1.0",
    "@testing-library/react":   "^16.0.0",
    "@testing-library/jest-dom":"^6.6.0",
    "@testing-library/user-event": "^14.5.0",
